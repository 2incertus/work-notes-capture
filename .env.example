# Required: webhook URL for AI processing (receives note JSON, returns summary + tasks)
# Set to empty or remove to disable AI processing (notes still save locally)
CHAINLIT_WEBHOOK_URL=http://localhost:8000/api/work-notes/process

# Optional: Vikunja task manager integration
# Get your API token from Vikunja > Settings > API Tokens
VIKUNJA_URL=http://localhost:3456
VIKUNJA_TOKEN=

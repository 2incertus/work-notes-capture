# Work Notes Capture -- Configuration
# Copy this file to .env and edit as needed.
# All integrations are optional. The app works standalone with just SQLite.

# ─────────────────────────────────────────────
# AI Processing Webhook (optional)
# ─────────────────────────────────────────────
# URL that receives a POST with note JSON on every capture.
# Your service processes the note (LLM summary, entity extraction, etc.)
# and calls back to POST /api/notes/{id}/result with the results.
#
# Leave empty or remove to disable AI processing.
# Notes still save locally -- you just won't get summaries.
#
# Examples:
#   CHAINLIT_WEBHOOK_URL=http://localhost:8000/api/work-notes/process
#   CHAINLIT_WEBHOOK_URL=http://my-ai-service:5000/process
#   CHAINLIT_WEBHOOK_URL=https://hooks.example.com/work-notes
CHAINLIT_WEBHOOK_URL=

# ─────────────────────────────────────────────
# Vikunja Task Manager (optional)
# ─────────────────────────────────────────────
# Connects the sidebar task panel to your Vikunja instance.
# Tasks appear in the sidebar. You can mark them complete from the UI.
# When AI processing creates tasks, they link back to source notes.
#
# To get your API token:
#   1. Open Vikunja > Settings > API Tokens
#   2. Create a token with read/write access
#   3. Paste it below
#
# If not set, the task panel shows "Vikunja not configured" and is hidden.
VIKUNJA_URL=http://localhost:3456
VIKUNJA_TOKEN=
